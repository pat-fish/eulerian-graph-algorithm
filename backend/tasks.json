{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "g++ build with vcpkg",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-o",
                "${fileDirname}/algo.exe",
                "${file}",
                "-I${env:VCPKG_ROOT}/installed/x64-windows/include",
                "-L${env:VCPKG_ROOT}/installed/x64-windows/lib"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}